{
  "default_block": { "Name": "minecraft:stone" },
  "default_fluid": { "Name": "minecraft:water" },
  "sea_level": 124,
  "disable_mob_generation": false,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,
  "noise": {
    "min_y": -64,
    "height": 384,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "barrier": 0.0,
    "vein_gap": 0.0,
    "vein_ridged": 0.0,
    "vein_toggle": 0.0,

    "fluid_level_floodedness": -1.0,
    "fluid_level_spread": 0.0,
    "lava": 0.0,

    "continents": {
      "type": "add",
      "argument1": {
        "type": "noise",
        "noise": "endfield_industries:continent",
        "xz_scale": 1,
        "y_scale": 0
      },
      "argument2": 0.11
    },
    "erosion": {
      "type": "noise",
      "noise": "endfield_industries:erosion",
      "xz_scale": 1,
      "y_scale": 0
    },
    "depth": {
      "type": "noise",
      "noise": "endfield_industries:depth",
      "xz_scale": 1,
      "y_scale": 0
    },
    "ridges": 0.0,
    "temperature": {
      "type": "noise",
      "noise": "endfield_industries:temperature",
      "xz_scale": 1,
      "y_scale": 0
    },
    "vegetation": 0.0,

    "final_density": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:y_clamped_gradient",
        "from_y": -64,
        "to_y": 320,
        "from_value": 1.5,
        "to_value": -1.5
      },
      "argument2": {
        "type": "max",
        /* Below Ground */
        "argument1": {
          "type": "minecraft:spline",
          "spline": {
            "coordinate": {
              "type": "noise",
              "noise": "endfield_industries:continent",
              "xz_scale": 1,
              "y_scale": 0
            },
            "points": [
              { "location": -1.0, "value": -1.0, "derivative": 1.0 },
              { "location": 0.0, "value": 0.0, "derivative": 0.0 },
              { "location": 1.0, "value": 0.0, "derivative": 0.0 }
            ]
          }
        },
        /* Above Ground */
        "argument2": {
          "type": "minecraft:spline",
          "spline": {
            "coordinate": {
              "type": "mul",
              "argument1": {
                "type": "spline",
                "spline": {
                  "coordinate": {
                    "type": "noise",
                    "noise": "endfield_industries:erosion",
                    "xz_scale": 1,
                    "y_scale": 0
                  },
                  "points": [
                    { "location": -1.0, "value": 1.0, "derivative": 0.0 },
                    { "location": 0.0, "value": 0.0, "derivative": 0.0 },
                    { "location": 1.0, "value": 0.0, "derivative": 0.0 }
                  ]
                }
              },
              "argument2": {
                "type": "minecraft:spline",
                "spline": {
                  "coordinate": {
                    "type": "noise",
                    "noise": "endfield_industries:continent",
                    "xz_scale": 1,
                    "y_scale": 0
                  },
                  "points": [
                    { "location": -1.0, "value": -1.0, "derivative": 0.0 },
                    { "location": 0.0, "value": 0.0, "derivative": 0.0 },
                    { "location": 0.5, "value": 1.0, "derivative": 0.0 }
                  ]
                }
              }
            },
            "points": [
              { "location": -1.0, "value": -1.0, "derivative": 0.0 },
              { "location": 0.0, "value": -1.0, "derivative": 0.0 },
              { "location": 0.00001, "value": 0.00001, "derivative": 1.0 },
              { "location": 1.0, "value": 1.0, "derivative": 1.0 }
            ]
          }
        }
      }
    },
    "initial_density_without_jaggedness": 0.0
  },

  "spawn_target": [],

  "surface_rule": {
